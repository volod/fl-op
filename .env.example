# fl-op environment configuration
# Copy this file to .env and adjust values for your local setup.
# All variables are optional; the defaults below match quickstart scale.

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------

# Root directory for all run artifacts (generated data, solve outputs, etc.)
DATA_DIR=.data

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Dataset generation defaults (quickstart scale)
# ---------------------------------------------------------------------------
# Override per-run:  make quickstart VEHICLES=200
# Or change here to make a new scale the default for all make targets.

VEHICLES=100
IMPLEMENTS=400
ORDERS=250
DEPOTS=50
# SEED=              # integer for reproducibility; leave blank for random

# ---------------------------------------------------------------------------
# Concurrency
# ---------------------------------------------------------------------------

# Parallel solver workers (0 = auto: min(n_clusters, cpu_count,
# memory-derived cap)). An explicit positive value always wins.
SOLVER_WORKERS=0

# Exact joint scheduling for backup operators shared across clusters. 0 (off):
# clusters solve in parallel and a backup is shared only over time-disjoint
# windows. 1: a scarce backup may be shared over overlapping windows, and the
# contending clusters solve sequentially so it is never double-booked.
OPERATOR_SHARING_SEQUENTIAL=0

# Total solve-time budget (seconds) for one sequential operator-sharing group,
# split across its clusters by penalty weight. 0 = each cluster keeps the
# per-cluster limit (a large group can run long); a positive value bounds it.
OPERATOR_SHARING_GROUP_TIME_LIMIT_S=0

# Memory-aware auto sizing: each worker is estimated as a base footprint plus
# the largest cluster's routing-model size; the worker count is bounded by
# how many such footprints fit into available memory, keeping the headroom
# share free. Tune the base/coefficient if measured worker RSS differs.
SOLVER_WORKER_BASE_MEMORY_MB=300.0
SOLVER_MODEL_BYTES_PER_CELL=64.0
SOLVER_MEMORY_HEADROOM_PCT=20.0

# ---------------------------------------------------------------------------
# Solver performance
# ---------------------------------------------------------------------------

# Wall-clock seconds per cluster worker before marking the cluster infeasible.
CLUSTER_SOLVE_TIME_LIMIT_S=60

# Target number of orders per geographic cluster sent to one solver worker.
CLUSTER_TARGET_SIZE=50

# Max vehicle-implement candidate pairs per order (caps OR-Tools model size).
MAX_PAIRS_PER_ORDER=30

# Optional Large Neighbourhood Search improvement pass: high-value clusters
# (total lateness penalty at or above the threshold) get a second solve from
# the first solution with guided local search and LNS operators.
CLUSTER_LNS_ENABLED=0
CLUSTER_LNS_TIME_LIMIT_S=10
CLUSTER_LNS_MIN_PENALTY_EUR_PER_DAY=1000.0

# ---------------------------------------------------------------------------
# Pre-allocation
# ---------------------------------------------------------------------------

# V-I pairs reserved per resource to support parallel cluster solving.
PREALLOC_ORDERS_PER_RESOURCE=5

# Minimum resources reserved for clusters that span multiple orders.
PREALLOC_MIN_RESOURCES_PER_MULTI_ORDER_CLUSTER=2

# CP-SAT global assignment model deciding all clusters at once (1 = on).
# The greedy reservation loop is the fallback when disabled, oversized, or
# the solve exceeds its time budget.
GLOBAL_ASSIGNMENT_ENABLED=1
GLOBAL_ASSIGNMENT_TIME_LIMIT_S=10.0

# Stop the assignment solve within this relative gap of the bound (cheap
# early exit that never costs an allocation, only tie-break polish).
GLOBAL_ASSIGNMENT_RELATIVE_GAP=0.001

# Best-scoring candidate (vehicle, implement) pairs kept per cluster, and the
# total candidate count above which the model falls back to greedy.
GLOBAL_ASSIGNMENT_CANDIDATES_PER_CLUSTER=100
GLOBAL_ASSIGNMENT_MAX_MODEL_CANDIDATES=20000

# Diversity caps inside one cluster's truncated candidate list, so the
# nearest vehicle does not flood the top-K with every implement pairing.
GLOBAL_ASSIGNMENT_PAIRS_PER_VEHICLE=2
GLOBAL_ASSIGNMENT_PAIRS_PER_IMPLEMENT=2

# ---------------------------------------------------------------------------
# Vehicle-implement compatibility
# ---------------------------------------------------------------------------

# Implement may draw up to this % above vehicle rated power (short-duration peaks).
# Increase for more lenient matching; decrease for a tighter safety headroom.
POWER_MARGIN_PCT=10.0

# Compatibility-matrix cache (keyed by a content hash of the power
# capabilities and margin, stored under $DATA_DIR/cache/compat-matrix).
COMPAT_MATRIX_CACHE_ENABLED=1
COMPAT_MATRIX_CACHE_MAX_ENTRIES=8

# ---------------------------------------------------------------------------
# Cost rates
# ---------------------------------------------------------------------------
# Fallback prices only: when the dataset carries cost-rate rows (prices source
# contract) valid at planning time, those rates win over these constants.

FUEL_COST_EUR_PER_L=1.45
FERTILIZER_COST_EUR_PER_KG=0.55

# ---------------------------------------------------------------------------
# Greedy scoring weights
# ---------------------------------------------------------------------------

# Relative weight of gross margin vs. repositioning cost in the greedy score.
# Increase SCORE_WEIGHT_REPOSITION to penalise distant vehicle moves more.
SCORE_WEIGHT_MARGIN=1.0
SCORE_WEIGHT_REPOSITION=1.0

# ---------------------------------------------------------------------------
# Declarative contract / canonical planning layer
# ---------------------------------------------------------------------------

# Root directory of the contract layer (Avro schemas, ODCS contracts, profiles).
CONTRACTS_DIR=contracts

# Active domain pack for this run (overrides registry.yaml activeDomain).
# Known domains: agricultural (default), construction (runnable), roadside
# (validation-level example pack).
# ACTIVE_DOMAIN=construction

# Periodic (batch) planning horizon and rolling (stream) dispatch horizon.
PERIODIC_HORIZON_DAYS=7
ROLLING_HORIZON_HOURS=48

# Tasks whose planned start falls within this window are frozen during rolling
# replanning and preserved verbatim across plan revisions.
FREEZE_WINDOW_MINUTES=60

# Score penalty per assignment changed after the freeze window (plan instability).
DEFAULT_CHANGE_PENALTY=1000

# ---------------------------------------------------------------------------
# Parameter tuning (Optuna) and experiment tracking (MLflow)
# ---------------------------------------------------------------------------

# Optuna trials per `fl-op tune` run and the TPE sampler seed.
TUNE_N_TRIALS=20
TUNE_SEED=7

# Per-cluster solve budget bounds for tuning trials (the baseline runs at the
# same trial-scale budget for comparability).
TUNE_TIME_LIMIT_MIN_S=5
TUNE_TIME_LIMIT_MAX_S=30

# Search bounds for the cluster target size and the greedy score weights.
TUNE_CLUSTER_TARGET_SIZE_MIN=10
TUNE_CLUSTER_TARGET_SIZE_MAX=80
TUNE_SCORE_WEIGHT_MIN=0.1
TUNE_SCORE_WEIGHT_MAX=5.0

# Opt-in MLflow run logging for plan runs and tuning trials (1 = on). The
# tracking store defaults to a local SQLite file under $DATA_DIR/mlruns;
# MLFLOW_TRACKING_URI points at a real tracking server instead.
MLFLOW_LOGGING_ENABLED=0
MLFLOW_EXPERIMENT_NAME=fl-op
# MLFLOW_TRACKING_URI=http://mlflow.example.internal:5000

# ---------------------------------------------------------------------------
# Serving (thin service API)
# ---------------------------------------------------------------------------

# Bind address and port for `fl-op serve`. The default binds loopback only;
# set SERVE_HOST=0.0.0.0 explicitly to expose the API beyond the host.
SERVE_HOST=127.0.0.1
SERVE_PORT=8000

# Auth mode: "" auto-infers (oidc if SERVE_OIDC_ISSUER set, static if tokens
# set, else open for loopback dev); force with none|static|oidc.
SERVE_AUTH_MODE=
# Static bearer tokens (comma-separated accept-list; list >1 for zero-downtime
# rotation). SERVE_AUTH_TOKEN (singular) is folded in for compatibility.
SERVE_AUTH_TOKENS=
# SERVE_AUTH_TOKEN=
# OIDC/JWT validation (requires the auth extra: pip install 'fl-op[auth]').
# SERVE_OIDC_ISSUER=https://issuer.example.com
# SERVE_OIDC_AUDIENCE=fl-op
# SERVE_OIDC_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
# SERVE_OIDC_HS256_SECRET=
SERVE_OIDC_ALGORITHMS=RS256
SERVE_OIDC_SCOPE_CLAIMS=scope,scp,roles
# Opt-in in-process rate limit per principal (0 disables) and audit logging.
SERVE_RATE_LIMIT_REQUESTS=0
SERVE_RATE_LIMIT_WINDOW_S=60
SERVE_AUDIT_LOG_ENABLED=1
# SERVE_AUDIT_LOG_FILENAME=audit.jsonl

# Artifact backend: filesystem (default, over SERVE_ARTIFACT_ROOT/DATA_DIR) or
# object-store (serves only runs that carry a _COMMITTED marker). Only the
# filesystem-backed reference object store ("local") is built in.
SERVE_ARTIFACT_BACKEND=filesystem
# SERVE_ARTIFACT_ROOT=/mnt/fl-op-artifacts
SERVE_OBJECT_STORE_KIND=local
# SERVE_OBJECT_STORE_LOCAL_ROOT=/mnt/fl-op-objstore
# SERVE_OBJECT_STORE_PREFIX=

# ---------------------------------------------------------------------------
# Event-bus ingestion (broker-backed execution events)
# ---------------------------------------------------------------------------

# Execution-event source for rolling planning: jsonl (default, reads the
# --events file), kafka (consumes the broker topic; requires the broker extra:
# pip install 'fl-op[broker]'), or redis (reads a stream through a consumer
# group; requires the redis extra: pip install 'fl-op[redis]').
EVENT_SOURCE_KIND=jsonl
EVENT_BROKER_BOOTSTRAP_SERVERS=localhost:9092
EVENT_BROKER_TOPIC=fl-op.execution-events
EVENT_BROKER_GROUP_ID=fl-op-rolling
EVENT_BROKER_POLL_TIMEOUT_S=1.0
EVENT_BROKER_MAX_EMPTY_POLLS=3

# Redis Streams source (EVENT_SOURCE_KIND=redis). EVENT_REDIS_URL overrides the
# host/port/db triple when set (e.g. redis://localhost:6379/0).
EVENT_REDIS_URL=
EVENT_REDIS_HOST=localhost
EVENT_REDIS_PORT=6379
EVENT_REDIS_DB=0
EVENT_REDIS_STREAM=fl-op.execution-events
EVENT_REDIS_GROUP=fl-op-rolling
EVENT_REDIS_CONSUMER=fl-op-1
EVENT_REDIS_BODY_FIELD=data
EVENT_REDIS_COUNT=10
EVENT_REDIS_BLOCK_MS=1000
EVENT_REDIS_MAX_EMPTY_POLLS=3

